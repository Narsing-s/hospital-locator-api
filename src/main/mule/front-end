<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Hospital Locator – Frontend</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <!-- Minimal styling via Pico CSS -->
  <link rel="stylesheet" href="https://unpkg.com/@picocss/pico@2.0.6/css/pico.min.css">
  <style>
    :root { --maxw: 1100px; }
    main { max-width: var(--maxw); margin: 2rem auto; }
    pre { background:#0b1020; color:#e7e7e7; padding:1rem; border-radius:8px; overflow:auto; }
    .row { display:grid; grid-template-columns: 1fr; gap: 1rem; }
    @media (min-width: 900px) { .row { grid-template-columns: 1fr 1fr; } }
    .card { border: 1px solid #e2e8f0; border-radius: 12px; padding: 1rem; }
    .muted { color:#667085; }
    .success { color:#0a7d33; }
    .error { color:#b42318; }
    .mono { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace; }
    .kv { display:flex; gap:.5rem; align-items:center; }
    .kv code { background:#f4f6fa; padding:.15rem .4rem; border-radius:6px; }
    .small { font-size:.9rem; }
  </style>
</head>
<body>
  <main>
    <h1>🏥 Hospital Locator – Demo Frontend</h1>
    <p class="muted">Backed by your RAML API: <span class="mono">/pincode</span>, <span class="mono">/hospitals/{id}/services</span>, <span class="mono">/patients</span></p>

    <!-- CONFIG -->
    <section class="card">
      <h3>Configuration</h3>
      <div class="row">
        <div>
          <label for="baseUrl">Base URL</label>
          <input id="baseUrl" type="url" placeholder="https://api.example.com" />
        </div>
        <div>
          <label for="authToken">Authorization (Bearer or custom)</label>
          <input id="authToken" type="text" placeholder="Bearer eyJhbGciOi..." />
        </div>
      </div>
      <div class="small muted kv" style="margin-top:.5rem;">
        <span>Headers sent:</span>
        <code>Content-Type: application/json</code>
        <span>and</span>
        <code>Authorization: &lt;your value&gt;</code>
      </div>
    </section>

    <!-- PINCODE SEARCH -->
    <section class="card">
      <h3>🔎 Find Hospitals by Pincode</h3>
      <form id="formPincode">
        <div class="row">
          <div>
            <label for="pincode">Pincode <span class="muted small">(required, number)</span></label>
            <input id="pincode" name="pincode" type="number" placeholder="531034" required />
          </div>
          <div style="display:flex; align-items:end;">
            <button type="submit">Search</button>
          </div>
        </div>
      </form>
      <div id="pincodeStatus" class="small muted"></div>
      <pre id="pincodeOut" hidden></pre>
    </section>

    <!-- HOSPITAL SERVICES -->
    <section class="card">
      <h3>🧰 Hospital Services</h3>
      <form id="formServices">
        <div class="row">
          <div>
            <label for="hospitalId">Hospital ID <span class="muted small">(required, string)</span></label>
            <input id="hospitalId" name="hospitalId" type="text" placeholder="1" required />
          </div>
          <div style="display:flex; align-items:end;">
            <button type="submit">Get Services</button>
          </div>
        </div>
      </form>
      <div id="servicesStatus" class="small muted"></div>
      <pre id="servicesOut" hidden></pre>
    </section>

    <!-- CREATE PATIENT -->
    <section class="card">
      <h3>➕ Create Patient</h3>
      <p class="muted small">Provide JSON matching your <span class="mono">patients</span> request schema.</p>
      <form id="formPatient">
        <textarea id="patientJson" rows="10" placeholder='{
  "firstName": "Asha",
  "lastName": "Rao",
  "age": 34,
  "gender": "F",
  "mobile": "9999912345",
  "address": {
    "line1": "Plot 12",
    "city": "Hyderabad",
    "pincode": 500081
  }
}'></textarea>
        <div style="margin-top:.5rem; display:flex; gap:.5rem;">
          <button type="submit">Create</button>
          <button type="button" id="btnFormat">Format JSON</button>
          <button type="button" id="btnSample">Load Sample</button>
        </div>
      </form>
      <div id="patientStatus" class="small muted"></div>
      <pre id="patientOut" hidden></pre>
    </section>

    <footer class="muted small" style="margin-top:2rem;">
      <p>Tip: If you see CORS errors in the console, enable CORS on the API or serve this file from the same origin.</p>
    </footer>
  </main>

  <script>
    // ---- CONFIG ----
    const els = {
      baseUrl: document.getElementById('baseUrl'),
      authToken: document.getElementById('authToken'),
      formPincode: document.getElementById('formPincode'),
      pincode: document.getElementById('pincode'),
      pincodeOut: document.getElementById('pincodeOut'),
      pincodeStatus: document.getElementById('pincodeStatus'),
      formServices: document.getElementById('formServices'),
      hospitalId: document.getElementById('hospitalId'),
      servicesOut: document.getElementById('servicesOut'),
      servicesStatus: document.getElementById('servicesStatus'),
      formPatient: document.getElementById('formPatient'),
      patientJson: document.getElementById('patientJson'),
      patientOut: document.getElementById('patientOut'),
      patientStatus: document.getElementById('patientStatus'),
      btnFormat: document.getElementById('btnFormat'),
      btnSample: document.getElementById('btnSample')
    };

    // Restore last-used values from localStorage
    (() => {
      const b = localStorage.getItem('hl_baseUrl');
      const t = localStorage.getItem('hl_authToken');
      if (b) els.baseUrl.value = b;
      if (t) els.authToken.value = t;
    })();

    function saveConfig() {
      localStorage.setItem('hl_baseUrl', els.baseUrl.value.trim());
      localStorage.setItem('hl_authToken', els.authToken.value.trim());
    }

    function headers() {
      const h = { 'Content-Type': 'application/json' };
      const token = els.authToken.value.trim();
      if (token) h['Authorization'] = token; // e.g., "Bearer <token>" or per your securityScheme
      return h;
    }

    function showJSON(preEl, obj) {
      preEl.hidden = false;
      preEl.textContent = JSON.stringify(obj, null, 2);
    }

    function showStatus(el, msg, type='info') {
      el.textContent = msg;
      el.classList.remove('success','error');
      if (type === 'success') el.classList.add('success');
      if (type === 'error') el.classList.add('error');
    }

    async function safeFetch(url, init) {
      saveConfig();
      try {
        const res = await fetch(url, init);
        // Attempt to parse JSON; if not JSON, fall back to text
        const ct = res.headers.get('content-type') || '';
        const payload = ct.includes('application/json') ? await res.json() : await res.text();
        return { ok: res.ok, status: res.status, data: payload };
      } catch (err) {
        return { ok: false, status: 0, data: { error: err.message } };
      }
    }

    // ----- PINCODE -----
    els.formPincode.addEventListener('submit', async (e) => {
      e.preventDefault();
      const base = els.baseUrl.value.trim().replace(/\/+$/,'');
      const pin = els.pincode.value.trim();
      if (!base) return showStatus(els.pincodeStatus, 'Please set Base URL', 'error');
      if (!pin) return showStatus(els.pincodeStatus, 'Please enter a pincode', 'error');

      showStatus(els.pincodeStatus, 'Fetching hospitals…');
      els.pincodeOut.hidden = true;

      const url = `${base}/pincode?pincode=${encodeURIComponent(pin)}`;
      const { ok, status, data } = await safeFetch(url, { method: 'GET', headers: headers() });

      if (ok) {
        showStatus(els.pincodeStatus, `✅ 200 OK`);
        showJSON(els.pincodeOut, data);
      } else {
        showStatus(els.pincodeStatus, `❌ ${status} error`, 'error');
        showJSON(els.pincodeOut, data);
      }
    });

    // ----- SERVICES -----
    els.formServices.addEventListener('submit', async (e) => {
      e.preventDefault();
      const base = els.baseUrl.value.trim().replace(/\/+$/,'');
      const id = els.hospitalId.value.trim();
      if (!base) return showStatus(els.servicesStatus, 'Please set Base URL', 'error');
      if (!id) return showStatus(els.servicesStatus, 'Please enter a hospital ID', 'error');

      showStatus(els.servicesStatus, 'Fetching services…');
      els.servicesOut.hidden = true;

      const url = `${base}/hospitals/${encodeURIComponent(id)}/services`;
      const { ok, status, data } = await safeFetch(url, { method: 'GET', headers: headers() });

      if (ok) {
        showStatus(els.servicesStatus, `✅ 200 OK`);
        showJSON(els.servicesOut, data);
      } else {
        showStatus(els.servicesStatus, `❌ ${status} error`, 'error');
        showJSON(els.servicesOut, data);
      }
    });

    // ----- CREATE PATIENT -----
    els.formPatient.addEventListener('submit', async (e) => {
      e.preventDefault();
      const base = els.baseUrl.value.trim().replace(/\/+$/,'');
      if (!base) return showStatus(els.patientStatus, 'Please set Base URL', 'error');

      let body;
      try {
        body = JSON.parse(els.patientJson.value);
      } catch (err) {
        return showStatus(els.patientStatus, 'Invalid JSON: ' + err.message, 'error');
      }

      showStatus(els.patientStatus, 'Creating patient…');
      els.patientOut.hidden = true;

      const url = `${base}/patients`;
      const { ok, status, data } = await safeFetch(url, {
        method: 'POST',
        headers: headers(),
        body: JSON.stringify(body)
      });

      if (ok) {
        showStatus(els.patientStatus, `✅ ${status} ${status === 200 ? 'OK' : ''}`);
        showJSON(els.patientOut, data);
      } else {
        showStatus(els.patientStatus, `❌ ${status} error`, 'error');
        showJSON(els.patientOut, data);
      }
    });

    // Helpers: format & sample
    els.btnFormat.addEventListener('click', () => {
      try {
        const obj = JSON.parse(els.patientJson.value);
        els.patientJson.value = JSON.stringify(obj, null, 2);
      } catch (e) {
        alert('Invalid JSON: ' + e.message);
      }
    });

    els.btnSample.addEventListener('click', () => {
      els.patientJson.value = JSON.stringify({
        firstName: "Asha",
        lastName: "Rao",
        age: 34,
        gender: "F",
        mobile: "9999912345",
        address: { line1: "Plot 12", city: "Hyderabad", pincode: 500081 }
      }, null, 2);
    });
  </script>
</body>
</html>
